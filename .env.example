# UniMatch 环境变量模板
# 复制为 .env 并填入真实值

# ------------------------
# 应用基础
# ------------------------
APP_NAME=UniMatch
DEBUG=true
SECRET_KEY=change-this-to-a-random-string-at-least-32-characters-long
ALLOWED_EMAIL_DOMAINS=shanghaitech.edu.cn
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ------------------------
# 数据库与缓存
# ------------------------
DATABASE_URL=postgresql+asyncpg://unimatch:unimatch@localhost:5432/unimatch
DATABASE_URL_SYNC=postgresql://unimatch:unimatch@localhost:5432/unimatch
REDIS_URL=redis://localhost:6379/0

# ------------------------
# 文件存储 (MinIO / S3)
# ------------------------
STORAGE_PROVIDER=minio
# STORAGE_PROVIDER=s3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=unimatch
MINIO_USE_SSL=false
# AWS_S3_BUCKET=...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ------------------------
# 邮箱配置（二选一）
# ------------------------
MAIL_PROVIDER=netease_126
# MAIL_PROVIDER=shanghaitech

# 上海科技大学邮箱（校内/VPN 环境）
SHANGHAITECH_SMTP_HOST=smtp.shanghaitech.edu.cn
SHANGHAITECH_SMTP_PORT=465
SHANGHAITECH_SENDER=yourname@shanghaitech.edu.cn
SHANGHAITECH_USERNAME=yourname@shanghaitech.edu.cn
SHANGHAITECH_PASSWORD=your-client-specific-password

# 126 邮箱（校外可用）
NETEASE126_SMTP_HOST=smtp.126.com
NETEASE126_SMTP_PORT=465
NETEASE126_SENDER=yourname@126.com
NETEASE126_USERNAME=yourname@126.com
NETEASE126_PASSWORD=your-authorization-code

# ------------------------
# 短信配置（开发默认 mock）
# ------------------------
SMS_PROVIDER=mock
# SMS_PROVIDER=twilio
# SMS_PROVIDER=tencent
# SMS_PROVIDER=aliyun
CODE_TTL=300
RATE_LIMIT_PER_PHONE=5
RATE_LIMIT_PER_EMAIL=5

TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxx

TENCENT_SECRET_ID=AKIDxxxxxxxx
TENCENT_SECRET_KEY=xxxxxxxx
TENCENT_SMS_APP_ID=1400xxxxxx
TENCENT_SMS_SIGN_NAME=校园匹配
TENCENT_SMS_TEMPLATE_ID=xxxxxx

ALIYUN_ACCESS_KEY_ID=LTAIxxxxxxxx
ALIYUN_ACCESS_KEY_SECRET=xxxxxxxx
ALIYUN_REGION=cn-hangzhou
ALIYUN_SMS_SIGN_NAME=校园匹配
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxx

# ------------------------
# AI 配置
# ------------------------
# 默认优先使用的 provider：deepseek | kimi | lmstudio | opencode | mimo
DEFAULT_AI_PROVIDER=deepseek

DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

KIMI_API_KEY=sk-xxxxxxxx
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# LMStudio / lms 本地模型，OpenAI-compatible
LMSTUDIO_API_KEY=not-needed
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen3.5-9b

# OpenCode / MIMO：待确认官方 API，先占位
OPENCODE_API_KEY=sk-xxxxxxxx
OPENCODE_BASE_URL=https://api.opencode.example.com/v1
OPENCODE_MODEL=opencode-model

MIMO_API_KEY=sk-xxxxxxxx
MIMO_BASE_URL=https://api.mimo.example.com/v1
MIMO_MODEL=mimo-model

# ------------------------
# 学校统一身份认证（预留，后续接入）
# ------------------------
CAS_ENABLED=false
CAS_BASE_URL=https://egate.shanghaitech.edu.cn/cas
CAS_SERVICE_URL=http://localhost:8000/auth/cas/callback
CAS_VERSION=3

# ------------------------
# 内容审核
# ------------------------
MODERATION_PROVIDER=local
MODERATION_SYNC=true
# 阿里云/腾讯/OpenAI 审核（可选）
# ALIYUN_CONTENT_SECURITY_KEY=...
# TENCENT_TMS_SECRET_ID=...
# OPENAI_API_KEY=...

# ------------------------
# Celery / 任务队列
# ------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
